# Transport: "stdio" (default) or "http"
TRANSPORT=stdio
PORT=3000

# Amazon Mechanical Turk (optional — adapter works in simulated mode without these)
MTURK_ACCESS_KEY_ID=
MTURK_SECRET_ACCESS_KEY=
MTURK_SANDBOX=true

# RentAHuman.ai (optional — adapter works in simulated mode without these)
RENTAHUMAN_API_KEY=

# Manual backend webhook (optional)
MANUAL_WEBHOOK_URL=
