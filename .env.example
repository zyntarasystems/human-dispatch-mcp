# Transport: "stdio" (default) or "http"
TRANSPORT=stdio
PORT=3000

# Manual backend webhook (optional)
MANUAL_WEBHOOK_URL=

# Pre-seed webhook providers on startup (optional)
# JSON array of provider objects. Example:
# PROVIDERS_CONFIG='[{"name":"My Provider","webhook_url":"https://example.com/webhook","webhook_secret":"your-secret-min-32-chars-long-here!!","categories":["digital_micro"],"task_types":["digital"],"regions":["*"],"min_budget_usd":1,"max_budget_usd":500,"max_concurrent_tasks":10}]'
PROVIDERS_CONFIG=
